sequenceDiagram
  autonumber
  actor A as Agent User
  participant Auth as Auth Middleware
  participant R as Agent Route
  participant C as Ticket Controller
  participant S as Ticket Service
  participant Repo as Ticket Repo
  participant DB as Prisma/PostgreSQL

  A->>Auth: PATCH /api/agents/me/availability
  Auth-->>R: req.user
  R->>C: updateMyAgentAvailability(request)
  C->>S: updateMyAgentAvailabilityService(organizationId, isAvailable, userId)

  S->>Repo: getTicketOrganizationMembership(organizationId, userId)
  Repo->>DB: Membership.findUnique(userId_orgId)
  DB-->>Repo: membership
  Repo-->>S: membership

  alt No membership
    S-->>C: throw 403
    C-->>A: 403 response
  else Membership found
    S->>S: membership.role === AGENT?
    alt Not AGENT
      S-->>C: throw 403
      C-->>A: 403 response
    else AGENT
      S->>Repo: updateAgentAvailability(organizationId, userId, isAvailable)
      Repo->>DB: Membership.update(isAvailable)
      DB-->>Repo: updated membership
      Repo-->>S: updated membership
      S-->>C: success
      C-->>A: 200 OK
    end
  end
