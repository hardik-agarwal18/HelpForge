{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Service Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "API Gateway",
      "description": "Prometheus target up status",
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "up{job=\"api-gateway\"}", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Chatbot Service",
      "description": "Prometheus target up status",
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "up{job=\"chatbot-service\"}", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "API Gateway \u2014 Apdex",
      "description": "User satisfaction score (T=500ms)",
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "(\n  sum(rate(helpforge_api_gateway_http_request_duration_seconds_bucket{le=\"0.5\"}[5m]))\n+\n  sum(rate(helpforge_api_gateway_http_request_duration_seconds_bucket{le=\"2\"}[5m]))\n) / 2\n/\nsum(rate(helpforge_api_gateway_http_request_duration_seconds_count[5m]))",
        "legendFormat": "Apdex"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0.5 },
            { "color": "yellow", "value": 0.75 },
            { "color": "green", "value": 0.9 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Chatbot \u2014 Apdex",
      "description": "User satisfaction score (T=1s)",
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "(\n  sum(rate(helpforge_chatbot_http_request_duration_seconds_bucket{le=\"1\"}[5m]))\n+\n  sum(rate(helpforge_chatbot_http_request_duration_seconds_bucket{le=\"5\"}[5m]))\n) / 2\n/\nsum(rate(helpforge_chatbot_http_request_duration_seconds_count[5m]))",
        "legendFormat": "Apdex"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0.5 },
            { "color": "yellow", "value": 0.75 },
            { "color": "green", "value": 0.9 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "API GW \u2014 Error %",
      "description": "5xx as percentage of total requests",
      "gridPos": { "h": 3, "w": 3, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum(rate(helpforge_api_gateway_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(helpforge_api_gateway_http_requests_total[5m])) * 100 or vector(0)",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Chatbot \u2014 Error %",
      "description": "5xx as percentage of total requests",
      "gridPos": { "h": 3, "w": 3, "x": 15, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "expr": "sum(rate(helpforge_chatbot_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(helpforge_chatbot_http_requests_total[5m])) * 100 or vector(0)",
        "legendFormat": ""
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      }
    },
    {
      "type": "stat",
      "title": "API GW \u2014 req/s",
      "gridPos": { "h": 3, "w": 3, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(rate(helpforge_api_gateway_http_requests_total[5m]))", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] } } }
    },
    {
      "type": "stat",
      "title": "Chatbot \u2014 req/s",
      "gridPos": { "h": 3, "w": 3, "x": 21, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum(rate(helpforge_chatbot_http_requests_total[5m]))", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } }
    },

    {
      "type": "row",
      "title": "API Gateway \u2014 Latency & Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum by (route) (rate(helpforge_api_gateway_http_requests_total[5m]))", "legendFormat": "{{ route }}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "none" }, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(helpforge_api_gateway_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum by (le) (rate(helpforge_api_gateway_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(helpforge_api_gateway_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(helpforge_api_gateway_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Status Codes",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum by (status_code) (rate(helpforge_api_gateway_http_requests_total[5m]))", "legendFormat": "{{ status_code }}" }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80, "stacking": { "mode": "normal" }, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "2.." }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "3.." }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "4.." }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "5.." }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Latency by Route (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, route) (rate(helpforge_api_gateway_http_request_duration_seconds_bucket[5m]))) > 0", "legendFormat": "{{ route }}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"], "sortBy": "Max", "sortDesc": true }, "tooltip": { "mode": "multi" } }
    },

    {
      "type": "row",
      "title": "Chatbot Service \u2014 Latency & Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Rate by Route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum by (route) (rate(helpforge_chatbot_http_requests_total[5m]))", "legendFormat": "{{ route }}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "none" }, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(helpforge_chatbot_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum by (le) (rate(helpforge_chatbot_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(helpforge_chatbot_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(helpforge_chatbot_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Status Codes",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "sum by (status_code) (rate(helpforge_chatbot_http_requests_total[5m]))", "legendFormat": "{{ status_code }}" }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80, "stacking": { "mode": "normal" }, "showPoints": "never" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "2.." }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "3.." }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "4.." }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "5.." }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Latency by Route (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, route) (rate(helpforge_chatbot_http_request_duration_seconds_bucket[5m]))) > 0", "legendFormat": "{{ route }}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"], "sortBy": "Max", "sortDesc": true }, "tooltip": { "mode": "multi" } }
    },

    {
      "type": "row",
      "title": "Database (Postgres)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "DB Write Health",
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "helpforge_api_gateway_db_healthy{role=\"write\"}", "legendFormat": "" }],
      "fieldConfig": { "defaults": {
        "mappings": [{ "type": "value", "options": { "0": { "text": "UNHEALTHY", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } } }],
        "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
      }}
    },
    {
      "type": "stat",
      "title": "DB Read Health",
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "helpforge_api_gateway_db_healthy{role=\"read\"}", "legendFormat": "" }],
      "fieldConfig": { "defaults": {
        "mappings": [{ "type": "value", "options": { "0": { "text": "UNHEALTHY", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } } }],
        "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
      }}
    },
    {
      "type": "stat",
      "title": "DB Queries",
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "helpforge_api_gateway_db_queries_total", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "DB Errors",
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "helpforge_api_gateway_db_query_errors_total", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "type": "timeseries",
      "title": "DB Query Latency",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "helpforge_api_gateway_db_query_latency_ms{quantile=\"0.5\"}", "legendFormat": "p50" },
        { "expr": "helpforge_api_gateway_db_query_latency_ms{quantile=\"0.95\"}", "legendFormat": "p95" },
        { "expr": "helpforge_api_gateway_db_query_latency_ms{quantile=\"0.99\"}", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "DB Circuit Breaker",
      "description": "1 = tripped (open), 0 = healthy (closed)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "helpforge_api_gateway_db_circuit_breaker_open{role=\"write\"}", "legendFormat": "Write CB" },
        { "expr": "helpforge_api_gateway_db_circuit_breaker_open{role=\"read\"}", "legendFormat": "Read CB" }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 30, "showPoints": "never" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    {
      "type": "row",
      "title": "Redis",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Redis Connections",
      "gridPos": { "h": 3, "w": 3, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "helpforge_api_gateway_redis_active_connections", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 15 }] } } }
    },
    {
      "type": "stat",
      "title": "Redis Commands",
      "gridPos": { "h": 3, "w": 3, "x": 3, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "helpforge_api_gateway_redis_commands_total", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "type": "stat",
      "title": "Redis Errors",
      "gridPos": { "h": 3, "w": 3, "x": 6, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "helpforge_api_gateway_redis_errors_total", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "type": "stat",
      "title": "Redis CB",
      "description": "Circuit breaker status",
      "gridPos": { "h": 3, "w": 3, "x": 9, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "helpforge_api_gateway_redis_circuit_breaker_open", "legendFormat": "" }],
      "fieldConfig": { "defaults": {
        "mappings": [{ "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" } } }],
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
      }}
    },
    {
      "type": "timeseries",
      "title": "Redis Command Latency",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 53 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "helpforge_api_gateway_redis_latency_ms{quantile=\"0.5\"}", "legendFormat": "p50" },
        { "expr": "helpforge_api_gateway_redis_latency_ms{quantile=\"0.95\"}", "legendFormat": "p95" },
        { "expr": "helpforge_api_gateway_redis_latency_ms{quantile=\"0.99\"}", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
