# ── Service ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ── API Gateway (all LLM + embedding calls proxy through here) ─────────────
API_GATEWAY_URL=http://api-gateway:3000
INTERNAL_SERVICE_TOKEN=change-me-shared-secret

# ── Internal API security ───────────────────────────────────────────────────
# Set INTERNAL_PREVIOUS_TOKEN to the old secret during a token rotation window
# so both old and new tokens are accepted simultaneously.
# INTERNAL_PREVIOUS_TOKEN=old-secret-here
#
# Comma-separated CIDRs/IPs allowed to call /internal/* endpoints.
# Leave empty to disable (local dev only).
# INTERNAL_ALLOWED_IPS=172.18.0.0/16,10.0.0.1
#
# Set to false only in local dev/test — always true in staging/production.
INTERNAL_HMAC_ENABLED=true
INTERNAL_TIMESTAMP_TOLERANCE_SECONDS=30

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
MEMORY_TTL_SECONDS=86400
CACHE_TTL_SECONDS=300

# ── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key

# ── RAG ────────────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MIN_RETRIEVAL_SCORE=0.70

# ── LLM ────────────────────────────────────────────────────────────────────
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_SECONDS=1.0

# ── Confidence thresholds ──────────────────────────────────────────────────
CONFIDENCE_AUTO_RESOLVE=0.85
CONFIDENCE_SUGGEST=0.65
CONFIDENCE_ESCALATE_MAX=0.30
