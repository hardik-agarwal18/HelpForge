generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  AGENT
  MEMBER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketSource {
  WEB
  EMAIL
  CHAT
  API
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  memberships Membership[]

  createdTickets  Ticket[] @relation("CreatedTickets")
  assignedTickets Ticket[] @relation("AssignedTickets")

  comments       TicketComment[]
  attachments    TicketAttachment[]
  activities     TicketActivityLog[]
  agentWorkloads AgentWorkload[]
  notifications  Notification[]

  tokenIssuedAt DateTime?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  updatedAt DateTime  @updatedAt

  notificationPreference NotificationPreference?
  refreshTokens          RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Organization {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  memberships            Membership[]
  tickets                Ticket[]
  tags                   Tag[]
  agentWorkloads         AgentWorkload[]
  notifications          Notification[]
  aiusages               AIUsage[]
  aiconfig               AIConfig?
  ticketSubmissionConfig TicketSubmissionConfig?
  scrapedPages           ScrapedPage[]
}

model Membership {
  id String @id @default(uuid())

  userId         String
  organizationId String

  role Role @default(MEMBER)

  isAvailable       Boolean @default(true)
  maxTicketsPerDay  Int?    @default(10)
  maxTicketsPerWeek Int?    @default(50)

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId, role, isAvailable, createdAt])
}

model Ticket {
  id          String  @id @default(uuid())
  title       String
  description String?

  status   TicketStatus @default(OPEN)
  priority Priority     @default(MEDIUM)
  source   TicketSource @default(WEB)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedTickets", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTickets", fields: [assignedToId], references: [id])

  // AI fields
  aiActive       Boolean @default(true)
  aiMessageCount Int     @default(0)

  category      String?
  comments      TicketComment[]
  attachments   TicketAttachment[]
  tags          TicketTag[]
  activities    TicketActivityLog[]
  notifications Notification[]

  resolvedAt      DateTime?
  firstResponseAt DateTime?
  dueAt           DateTime?

  resolvedBy        String? // "AI" | "AGENT"
  resolutionSummary String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  aidecisionLogs AIDecisionLog[]
  aifeedbacks    AIFeedback[]
  aiusages       AIUsage[]
  ticketSummary  TicketSummary?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([organizationId])
  @@index([assignedToId])
  @@index([status])
  @@index([organizationId, status])
  @@index([organizationId, assignedToId])
  @@index([createdAt])
}

model TicketComment {
  id String @id @default(uuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id])

  authorType CommentAuthorType

  message String

  isInternal Boolean @default(false)

  metadata Json?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt      DateTime        @default(now())
  aidecisionLogs AIDecisionLog[]
  aifeedbacks    AIFeedback[]
}

enum CommentAuthorType {
  USER
  AI
  SYSTEM
}

model TicketAttachment {
  id String @id @default(uuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  uploadedBy String
  uploader   User   @relation(fields: [uploadedBy], references: [id])

  fileUrl  String
  fileType String
  fileSize Int

  createdAt DateTime @default(now())
}

model Tag {
  id String @id @default(uuid())

  name           String
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id])
  tickets      TicketTag[]

  @@unique([organizationId, name])
}

model TicketTag {
  ticketId String
  tagId    String

  ticket Ticket @relation(fields: [ticketId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([ticketId, tagId])
}

model TicketActivityLog {
  id String @id @default(uuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  action   TicketActivityAction
  oldValue String?
  newValue String?

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

model AgentWorkload {
  id String @id @default(uuid())

  userId         String
  organizationId String

  assignedToday    Int @default(0)
  assignedThisWeek Int @default(0)

  activeTickets Int      @default(0)
  skills        String[]

  lastDailyReset  DateTime
  lastWeeklyReset DateTime

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([organizationId, assignedToday, assignedThisWeek, userId])
}

model Notification {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  recipientId String
  recipient   User   @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  type NotificationType

  title    String
  message  String
  metadata Json?

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([recipientId, isRead, createdAt])
  @@index([organizationId, createdAt])
  @@index([ticketId, createdAt])
}

model NotificationPreference {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  inAppEnabled              Boolean            @default(true)
  emailEnabled              Boolean            @default(false)
  pushEnabled               Boolean            @default(false)
  websocketEnabled          Boolean            @default(true)
  suppressSelfNotifications Boolean            @default(true)
  disabledTypes             NotificationType[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TicketActivityAction {
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_ASSIGNED
  TICKET_STATUS_UPDATED
  COMMENT_ADDED
  COMMENT_DELETED
  ATTACHMENT_ADDED
  ATTACHMENT_DELETED
  TAG_ADDED
  TAG_REMOVED
}

enum NotificationType {
  TICKET_ASSIGNED
  TICKET_COMMENT_ADDED
  TICKET_COMMENT_DELETED
  TICKET_TAG_ADDED
  TICKET_TAG_REMOVED
  TICKET_ATTACHMENT_ADDED
  TICKET_ATTACHMENT_DELETED
}

model AIDecisionLog {
  id String @id @default(uuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  commentId String?
  comment   TicketComment? @relation(fields: [commentId], references: [id])

  confidence     Float
  action         String
  reasoning      String
  recommendation String

  tokensUsed Int?
  model      String?

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

model AIUsage {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  tokensUsed Int
  cost       Float
  model      String

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
}

model AIFeedback {
  id String @id @default(uuid())

  ticketId  String
  commentId String

  ticket  Ticket        @relation(fields: [ticketId], references: [id])
  comment TicketComment @relation(fields: [commentId], references: [id])

  isHelpful Boolean
  feedback  String?

  createdAt DateTime @default(now())
}

model AIConfig {
  id String @id @default(uuid())

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  allowedModels String[] @default(["gpt-4", "gpt-3.5"])

  maxTokensPerRequest Int    @default(2000)
  maxCostPerDay       Float?

  enableAutoResolve Boolean @default(true)
  enableSmartAssign Boolean @default(true)

  autoResolveThreshold Float @default(0.85)
  suggestThreshold     Float @default(0.5)
  smartAssignThreshold Float @default(0.65)

  maxAIResponses Int @default(5)

  aiEnabled Boolean @default(true)

  createdAt DateTime @default(now())
}

model TicketSummary {
  id String @id @default(uuid())

  ticketId String @unique
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  summary       String
  lastUpdatedAt DateTime

  createdAt DateTime @default(now())
}

model AIProcessingLock {
  id String @id @default(uuid())

  ticketId  String
  commentId String @unique

  status String // processing | completed | failed

  createdAt DateTime @default(now())
}

model AIProcessingFailure {
  id String @id @default(uuid())

  queueName String
  jobName   String
  jobId     String?

  ticketId  String?
  commentId String?

  attemptsMade Int     @default(0)
  retryLimit   Int     @default(0)
  retryable    Boolean @default(true)
  retryCount   Int     @default(0)

  failureReason String
  stacktrace    String?
  payload       Json

  failedAt      DateTime  @default(now())
  lastRetriedAt DateTime?
  resolvedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([queueName, failedAt])
  @@index([ticketId, failedAt])
  @@index([commentId, failedAt])
  @@index([retryable, resolvedAt, failedAt])
  @@map("AIProcessingFailures")
}

model EventStore {
  id String @id @default(uuid())

  eventType String
  payload   Json

  ticketId String?

  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([ticketId, createdAt])
}

model TicketSubmissionConfig {
  id String @id @default(uuid())

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  // UX behavior
  mode SubmissionMode @default(FLEXIBLE)

  requireDescription Boolean @default(true)
  requireAttachments Boolean @default(false)

  minDescriptionLength Int @default(0)
  maxMessagesBeforeAI  Int @default(3)

  enableMessageBatching Boolean @default(true)
  batchingWindowMs      Int     @default(5000)

  enableSpamProtection Boolean @default(true)
  maxMessagesPerMinute Int     @default(5)

  createdAt DateTime @default(now())
}

enum SubmissionMode {
  STRICT // One detailed message required
  GUIDED // Ask follow-up questions
  FLEXIBLE // Free chat
}

// ── Web Scraper ───────────────────────────────────────────────────────────────

enum ScrapeStatus {
  PENDING     // Queued, not yet started
  PROCESSING  // Worker has picked up the job
  COMPLETED   // Successfully scraped and embedded
  FAILED      // Permanent failure after all retries
  STALE       // Marked stale by cleanup cron (vectors deleted)
}

model ScrapedPage {
  id      String @id @default(uuid())

  orgId   String
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  /// Original URL — displayed in dashboards and error messages
  url     String

  /// SHA-256 of url — used for fast unique-per-org lookup, avoids full URL index bloat
  urlHash String

  /// SHA-256 of the extracted text — deduplication gate (skip embedding if unchanged)
  contentHash    String?

  status         ScrapeStatus @default(PENDING)

  /// Number of Qdrant chunks created for this page (0 when hash unchanged / not yet embedded)
  chunkCount     Int      @default(0)

  /// Last time the page was fetched (even if hash unchanged)
  lastScrapedAt  DateTime?

  /// Last time vectors were actually written to Qdrant
  lastEmbeddedAt DateTime?

  errorMessage   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, urlHash])
  @@index([orgId])
  @@index([orgId, status])
  @@index([lastScrapedAt])
  @@index([createdAt])          // used by cleanup cron
}
